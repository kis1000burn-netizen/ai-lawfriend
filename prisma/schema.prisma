  reportId         String
  attachmentType   IllegalLendingAttachmentType @default(OTHER)
  originalName     String
  storedName       String
  mimeType         String
  sizeBytes        Int
  storageProvider  String                       @default("local")
  storageKey       String?
  storagePath      String
  downloadCount    Int                          @default(0)
  lastDownloadedAt DateTime?
  memo             String?
  uploadedByName   String?
  uploadedByPhone  String?
  createdAt        DateTime                     @default(now())

  report IllegalLendingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([attachmentType])
  @@index([createdAt])
}

model IllegalLendingLawyerReviewRequest {
  id                 String                           @id @default(cuid())
  reportId           String
  status             IllegalLendingLawyerReviewStatus @default(REQUESTED)
  requestedById      String?
  requestedByName    String?
  requestedByRole    String?
  memo               String?
  assignedLawyerId   String?
  assignedLawyerName String?
  autoAssigned       Boolean                          @default(false)
  assignmentReason   String?
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt

  report IllegalLendingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@index([createdAt])
}

model IllegalLendingLawyerAssignmentHistory {
  id              String   @id @default(cuid())
  reportId        String
  reviewRequestId String?
  lawyerId        String?
  lawyerName      String?
  reason          String?
  createdAt       DateTime @default(now())

  report IllegalLendingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([lawyerId])
  @@index([createdAt])
}

model JeonseDamageReport {
  id                   String             @id @default(cuid())
  reporterType         JeonseReporterType
  reporterName         String
  reporterPhone        String
  reporterEmail        String?
  tenantName           String?
  tenantPhone          String?
  propertyAddress      String
  propertyType         String?
  moveInDate           DateTime?
  fixedDate            DateTime?
  hasMoveInReport      Boolean            @default(false)
  hasFixedDate         Boolean            @default(false)
  hasPossession        Boolean            @default(false)
  hasLeaseRegistration Boolean            @default(false)
  hasJeonseRight       Boolean            @default(false)
  leaseStartDate       DateTime?
  leaseEndDate         DateTime?
  depositAmount        Int?
  monthlyRentAmount    Int?
  contractMemo         String?
  landlordName         String?
  landlordPhone        String?
  landlordAddress      String?
  landlordMemo         String?
  brokerName           String?
  brokerOfficeName     String?
  brokerPhone          String?
  brokerMemo           String?
  damageTypes          JeonseDamageType[]
  returnRequestHistory String?
  auctionOrSaleStatus  String?
  investigationStatus  String?
  damageSummary        String
  requestedHelp        String?
  evidenceSummary      String?
  generatedSummary     String
  generatedChecklist   String
  consentPrivacy       Boolean            @default(false)
  consentNoLegalAdvice Boolean            @default(false)
  uploadToken          String?            @unique
  status               JeonseReportStatus @default(DRAFT_SUBMITTED)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  statusHistories      JeonseDamageReportStatusHistory[]
  accessLogs           JeonseDamageReportAccessLog[]
  attachments          JeonseDamageReportAttachment[]
  lawyerReviewRequests JeonseDamageLawyerReviewRequest[]

  @@index([createdAt])
  @@index([status])
  @@index([reporterPhone])
  @@index([propertyAddress])
}

enum JeonseDamageAttachmentType {
  LEASE_CONTRACT
  RESIDENT_REGISTRATION
  FIXED_DATE_PROOF
  REGISTRY_CERTIFICATE
  DEPOSIT_TRANSFER
  RETURN_REQUEST_MESSAGE
  CONTENT_CERTIFIED_MAIL
  AUCTION_OR_SEIZURE_DOCUMENT
  INVESTIGATION_DOCUMENT
  BROKER_DOCUMENT
  OTHER
}

enum JeonseDamageLawyerReviewStatus {
  REQUESTED
  ASSIGNED
  REVIEWING
  COMPLETED
  CANCELLED
}

enum WageClaimReporterType {
  WORKER
  FAMILY_OR_RELATED
  REPRESENTATIVE
  OTHER
}

enum WageClaimEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  DAILY
  FREELANCER_DISPUTED
  OTHER
}

enum WageClaimDamageType {
  UNPAID_WAGES
  UNPAID_SEVERANCE
  UNPAID_OVERTIME
  UNPAID_NIGHT_HOLIDAY
  UNPAID_ALLOWANCE
  MINIMUM_WAGE_VIOLATION
  WAGE_STATEMENT_NOT_PROVIDED
  DELAYED_PAYMENT_AFTER_RESIGNATION
  OTHER
}

enum WageClaimReportStatus {
  DRAFT_SUBMITTED
  REVIEW_READY
  DOCUMENTS_CHECKED
  REFERRED_TO_LAWYER
  CLOSED
}

model JeonseDamageReportStatusHistory {
  id         String              @id @default(cuid())
  reportId   String
  fromStatus JeonseReportStatus?
  toStatus   JeonseReportStatus
  reason     String?
  actorId    String?
  actorName  String?
  actorRole  String?
  createdAt  DateTime            @default(now())

  report JeonseDamageReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([createdAt])
  @@index([toStatus])
}

model JeonseDamageReportAccessLog {
  id        String   @id @default(cuid())
  reportId  String
  action    String
  actorId   String?
  actorName String?
  actorRole String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  report JeonseDamageReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([action])
  @@index([createdAt])
}

model JeonseDamageReportAttachment {
  id               String                     @id @default(cuid())
  reportId         String
  attachmentType   JeonseDamageAttachmentType @default(OTHER)
  originalName     String
  storedName       String
  mimeType         String
  sizeBytes        Int
  storageProvider  String                     @default("local")
  storageKey       String?
  storagePath      String
  memo             String?
  uploadedByName   String?
  uploadedByPhone  String?
  downloadCount    Int                        @default(0)
  lastDownloadedAt DateTime?
  createdAt        DateTime                   @default(now())

  report JeonseDamageReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([attachmentType])
  @@index([createdAt])
}

model JeonseDamageLawyerReviewRequest {
  id                 String                         @id @default(cuid())
  reportId           String
  status             JeonseDamageLawyerReviewStatus @default(REQUESTED)
  requestedById      String?
  requestedByName    String?
  requestedByRole    String?
  memo               String?
  assignedLawyerId   String?
  assignedLawyerName String?
  autoAssigned       Boolean                        @default(false)
  assignmentReason   String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  report JeonseDamageReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@index([createdAt])
}

model WageClaimReport {
  id String @id @default(cuid())

  reporterType  WageClaimReporterType
  reporterName  String
  reporterPhone String
  reporterEmail String?

  workerName  String?
  workerPhone String?

  employerName     String?
  companyName      String
  companyAddress   String?
  companyPhone     String?
  workplaceAddress String?

  employmentType  WageClaimEmploymentType
  jobDescription  String?
  hireDate        DateTime?
  resignationDate DateTime?
  isResigned      Boolean                 @default(false)

  monthlyWageAmount Int?
  dailyWageAmount   Int?
  hourlyWageAmount  Int?
  agreedPayMemo     String?

  unpaidWageAmount      Int?
  unpaidSeveranceAmount Int?
  unpaidAllowanceAmount Int?
  unpaidTotalAmount     Int?
  unpaidPeriod          String?
  paymentDueDate        DateTime?

  damageTypes     WageClaimDamageType[]
  requestHistory  String?
  evidenceSummary String?
  damageSummary   String
  requestedHelp   String?

  generatedStatement String
  generatedTable     String
  generatedChecklist String

  consentPrivacy       Boolean @default(false)
  consentNoLegalAdvice Boolean @default(false)

  uploadToken String?               @unique
  status      WageClaimReportStatus @default(DRAFT_SUBMITTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([reporterPhone])
  @@index([companyName])
}

model LegalDocument {
  id                 String              @id @default(cuid())
  caseId             String
  type               LegalDocumentType
  status             LegalDocumentStatus @default(DRAFT)
  title              String
  questionSetVersion String?
  templateCode       String?
  templateVersion    String?
  latestApprovedAt   DateTime?
  latestApprovedById String?
  lockedAt           DateTime?
  lockedById         String?
  body               String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  case            Case                     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  generationTrace DocumentGenerationTrace?
  paragraphs      LegalDocumentParagraph[]
  versions        LegalDocumentVersion[]

  @@index([caseId, type])
  @@index([status])
}

model LegalDocumentParagraph {
  id                   String               @id @default(cuid())
  documentId           String
  sectionKey           String
  paragraphKey         String
  title                String
  displayOrder         Int
  content              String               @db.Text
  status               LegalParagraphStatus @default(DRAFT)
  generationMode       String
  aiPromptKey          String?
  lockOnApproval       Boolean              @default(true)
  supportsRegeneration Boolean              @default(true)
  supportsRestore      Boolean              @default(true)
  lockedAt             DateTime?
  lockedById           String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  document  LegalDocument                   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  histories LegalDocumentParagraphHistory[]

  @@unique([documentId, sectionKey, paragraphKey])
  @@index([documentId, displayOrder])
  @@index([status])
}

model LegalDocumentParagraphHistory {
  id            String   @id @default(cuid())
  paragraphId   String
  versionNo     Int
  action        String
  beforeContent String?  @db.Text
  afterContent  String?  @db.Text
  actorUserId   String?
  reason        String?
  createdAt     DateTime @default(now())

  paragraph LegalDocumentParagraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)

  @@index([paragraphId, versionNo])
}

model LegalDocumentVersion {
  id           String    @id @default(cuid())
  documentId   String
  versionNo    Int
  snapshotJson Json
  approved     Boolean   @default(false)
  approvedAt   DateTime?
  approvedById String?
  createdAt    DateTime  @default(now())

  document LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNo])
  @@index([documentId, approved])
}

model DocumentGenerationTrace {
  id                  String                 @id @default(cuid())
  legalDocumentId     String                 @unique
  templateCode        String
  templateVersion     String
  templateTitle       String
  sourceProvider      LegalFormProvider
  sourceId            String?
  sourceName          String?
  sourceUrl           String?
  sourceHash          String?
  sourceStatus        LegalFormSourceStatus?
  sourceNote          String?
  generatedSnapshotAt DateTime               @default(now())
  approvedSnapshotAt  DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  legalDocument LegalDocument @relation(fields: [legalDocumentId], references: [id], onDelete: Cascade)

  @@index([sourceProvider])
  @@index([sourceId])
  @@index([generatedSnapshotAt])
  @@index([approvedSnapshotAt])
}

model CaseTimelineEvent {
  id          String   @id @default(cuid())
  caseId      String
  type        String
  title       String
  description String?
  metaJson    Json?
  actorUserId String?
  createdAt   DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
}

/// 사건 인터뷰(AID-QS) 질문셋 — `questions` = 인터뷰 런타임(플랫 JSON). `definitionJson`(섹션·Zod) = 관리/게시
/// 구조; 인터뷰 필수 검증 EVIDENCE-20260423-330: 런타임은 `questions`만(§ SPEC Step3 싱글소스 A안).
model QuestionSet {
  id                     String            @id @default(cuid())
  name                   String
  code                   String?
  description            String?
  isActive               Boolean           @default(true)
  questions              Json              @default("[]")
  version                String            @default("1.0.0")
  catalogStatus          QuestionSetStatus @default(DRAFT)
  supportedDocumentTypes Json              @default("[]")
  visibleToRoles         Json              @default("[]")
  /// 카탈로그(섹션) Zod 구조. 인터뷰 런타임/완료 필수는 getActiveQuestionSet().questions(EVIDENCE-330).
  definitionJson         Json?
  publishedAt            DateTime?
  archivedAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  caseInterviewBindings Case[] @relation("CaseInterviewQuestionSet")

  @@index([isActive, updatedAt])
  @@index([createdAt])
  @@index([catalogStatus])
}

model LegalFormSource {
  id               String                @id @default(cuid())
  provider         LegalFormProvider
  sourceName       String
  sourceUrl        String
  documentType     String
  category         String?
  officialFormCode String?
  fileName         String?
  fileMimeType     String?
  fileHash         String?
  storageKey       String?
  licenseNote      String?
  downloadedAt     DateTime?
  effectiveDate    DateTime?
  parsedText       String?               @db.Text
  status           LegalFormSourceStatus @default(ACTIVE)
  memo             String?               @db.Text
  createdByUserId  String?
  updatedByUserId  String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  templates DocumentTemplate[]

  @@index([provider, status])
  @@index([documentType, status])
  @@index([sourceName])
  @@index([fileHash])
  @@index([createdAt])
}

/// 문서 템플릿(섹션/문단 정의) — definitionJson에 DocumentTemplateDefinition 저장
/// catalogStatus는 질문셋과 동일 enum(`QuestionSetStatus`)을 재사용한다.
model DocumentTemplate {
  id             String            @id @default(cuid())
  code           String
  version        String
  type           LegalDocumentType
  title          String
  description    String?
  definitionJson Json
  /// 공식서식 출처 연결. 내부 표준 템플릿이면 sourceProvider = INTERNAL_STANDARD, sourceId = null 허용.
  sourceId       String?
  sourceProvider LegalFormProvider @default(INTERNAL_STANDARD)
  sourceUrl      String?
  sourceHash     String?
  sourceNote     String?
  catalogStatus  QuestionSetStatus @default(DRAFT)
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  source LegalFormSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([code, version])
  @@index([type])
  @@index([catalogStatus])
  @@index([sourceId])
  @@index([sourceProvider])
}
