  PUBLISHED
}

/// CMB CaseType config revision — Publish/Lock workflow (Phase 6-F)
model AibeopchinCmbConfigRevision {
  id              String                   @id @default(cuid())
  caseType        String
  configId        String
  version         String
  status          AibeopchinCmbConfigStatus @default(DRAFT)
  configJson      Json
  evidenceTag     String
