model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String?
  name            String
  phone           String?
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  /// 일반 가입·소셜 이메일 검증 시각 — 미검증이면 null (MVP에서는 선택 적용).
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  cases               Case[]             @relation("UserCases")
  auditLogs           AuditLog[]         @relation("UserAuditLogs")
  uploadedAttachments CaseAttachment[]   @relation("UserUploadedCaseAttachments")
  litigationUploadedFiles LitigationUploadedFile[] @relation("UserLitigationUploadedFiles")
  timelineMemos       CaseTimelineMemo[] @relation("UserCaseTimelineMemos")
  assignedCases       CaseAssignment[]   @relation("UserAssignedCases")
  createdAssignments  CaseAssignment[]   @relation("UserCreatedAssignments")

  createdAlertRules           AlertRule[]                       @relation("AlertRuleCreatedBy")
  updatedAlertRules           AlertRule[]                       @relation("AlertRuleUpdatedBy")
  alertEventsActed            AlertEvent[]                      @relation("AlertEventActor")
  alertEventsAcknowledged     AlertEvent[]                      @relation("AlertEventAcknowledgedBy")
  alertEventsIgnored          AlertEvent[]                      @relation("AlertEventIgnoredBy")
  alertEventsResolved         AlertEvent[]                      @relation("AlertEventResolvedBy")
  alertEventsAssigned         AlertEvent[]                      @relation("AlertAssignee")
  escalationsReleased         AlertEscalation[]                 @relation("EscalationReleasedBy")
  adminNotifications          AdminNotification[]
  alertBoardFilterPresets     AlertBoardFilterPreset[]
  bulkActionJobs              BulkActionJob[]                   @relation("BulkActionJobActor")
  canceledBulkActionJobs      BulkActionJob[]                   @relation("BulkActionJobCanceledBy")
  opsQueueTicketsAssigned     OpsQueueTicket[]                  @relation("OpsQueueTicketAssignee")
  timelineExportLogs          TimelineExportLog[]
  paragraphRewriteHistories   DocumentParagraphRewriteHistory[]
  documentParagraphVersions   DocumentParagraphVersion[]        @relation("UserParagraphVersions")
  ownedCasePackageShares      CasePackageShare[]                @relation("CasePackageShareOwner")
  lawyerCasePackageShares     CasePackageShare[]                @relation("CasePackageShareLawyer")
  casePackageAccessLogs       CasePackageAccessLog[]            @relation("CasePackageAccessLogActor")
  requestedSupplementRequests SupplementRequest[]               @relation("SupplementRequestRequester")
  targetSupplementRequests    SupplementRequest[]               @relation("SupplementRequestTarget")
  supplementResponses         SupplementResponse[]              @relation("SupplementResponseResponder")
  supplementRequestStatusLogs SupplementRequestStatusLog[]      @relation("SupplementRequestStatusLogActor")
  supplementRequestAuditLogs  SupplementRequestAuditLog[]       @relation("SupplementRequestAuditLogActor")
  authAccounts                AuthAccount[]
  lawyerProfile               LawyerProfile?
  lawyerProfilesReviewed      LawyerProfile[]                   @relation("LawyerProfileReviewer")
  gongbuhoPacketsCreated      GongbuhoPacket[]                  @relation("GongbuhoPacketCreatedBy")
  gongbuhoPacketsApproved     GongbuhoPacket[]                  @relation("GongbuhoPacketApprovedBy")
  legalKnowledgeIntakesCreated LegalKnowledgeDemandIntake[]     @relation("LegalKnowledgeIntakeCreatedBy")
  legalKnowledgeBriefsPrepared LegalKnowledgeResearchBrief[]   @relation("LegalKnowledgeBriefPreparedBy")
  voiceTranscriptsCreated     VoiceTranscript[]                 @relation("VoiceTranscriptCreatedBy")
  voiceInteractionTracesActor VoiceInteractionTrace[]           @relation("VoiceInteractionTraceActor")
  voiceLawyerReviewCompletions VoiceLawyerReviewCompletion[]    @relation("VoiceLawyerReviewCompletionReviewer")
  voicePrivacyOpsRequestsCreated  VoicePrivacyOpsRequest[]        @relation("VoicePrivacyOpsRequestCreatedBy")
  voicePrivacyOpsRequestsAssigned VoicePrivacyOpsRequest[]        @relation("VoicePrivacyOpsRequestAssignedTo")
  voicePrivacyOpsRequestsResolved VoicePrivacyOpsRequest[]        @relation("VoicePrivacyOpsRequestResolvedBy")
  cmbRevisionsCreated          AibeopchinCmbConfigRevision[]    @relation("CmbRevisionCreatedBy")
  cmbPublishEventsActed        AibeopchinCmbPublishEvent[]      @relation("CmbPublishEventActor")
  createdCaseIntelligenceSnapshots CaseIntelligenceSnapshot[] @relation("CaseIntelligenceSnapshotCreator")
  clientDisclosureReleases         CaseClientDisclosureRelease[] @relation("CaseClientDisclosureReleaseActor")
  evidenceMappingItemReviews     LitigationEvidenceMappingItemReview[] @relation("UserEvidenceMappingItemReviews")
  documentIntelligenceReviewDecisions LitigationDocumentIntelligenceReviewDecision[] @relation("UserDocumentIntelligenceReviewDecisions")
  litigationDeadlinesCreated          LitigationDeadline[] @relation("UserLitigationDeadlinesCreated")
  litigationTasksCreated              LitigationTask[] @relation("UserLitigationTasksCreated")
  litigationTasksAssigned             LitigationTask[] @relation("UserLitigationTasksAssigned")
  litigationDraftContextsCreated      LitigationDraftContext[] @relation("UserLitigationDraftContextsCreated")
  documentIntelligenceOpsSyncs        LitigationDocumentIntelligenceOpsSync[] @relation("UserDocumentIntelligenceOpsSyncs")
  clientPortalAccessGrants            CaseClientPortalAccess[] @relation("CaseClientPortalAccessClient")
  clientPortalAccessInvites           CaseClientPortalAccess[] @relation("CaseClientPortalAccessInviter")
  clientSubmissions                   ClientSubmission[] @relation("ClientSubmissionSubmitter")
  clientSubmissionReviews             ClientSubmission[] @relation("ClientSubmissionReviewer")
  conversationMessagesSent            CaseConversationMessage[] @relation("CaseConversationMessageSender")
  sharedDocumentsProvided             CaseSharedDocument[] @relation("CaseSharedDocumentSharer")
  sharedDocumentsReceived             CaseSharedDocument[] @relation("CaseSharedDocumentRecipient")
  documentDeliveriesReceived          CaseDocumentDelivery[] @relation("CaseDocumentDeliveryRecipient")
  documentDeliveriesCreated           CaseDocumentDelivery[] @relation("CaseDocumentDeliveryCreator")
  externalMessageLogsReceived         ExternalMessageLog[] @relation("ExternalMessageLogRecipient")
  clientNotificationPreference        ClientNotificationPreference?
  clientPushSubscriptions             ClientPushSubscription[]
  tenantMemberships                   TenantMembership[]
  aiLawyerReviewFeedbacksGiven        AiLawyerReviewFeedback[]          @relation("AiLawyerReviewFeedbackLawyer")
  deadlineNotificationsReceived       LitigationDeadlineNotification[] @relation("LitigationDeadlineNotificationRecipient")
  deadlineNotificationsCreated        LitigationDeadlineNotification[] @relation("LitigationDeadlineNotificationCreator")
  retryJobsResolved                   RetryJob[] @relation("RetryJobResolvedBy")
  documentPipelineJobsResolved        DocumentPipelineJob[] @relation("DocumentPipelineJobResolvedBy")
  lawyerMatchingRecommendationsCreated  LawyerMatchingRecommendation[] @relation("LawyerMatchingRecommendationCreatedBy")
  lawyerMatchingRecommendationsApproved LawyerMatchingRecommendation[] @relation("LawyerMatchingRecommendationApprovedBy")
  lawyerMatchingRecommendationsRejected LawyerMatchingRecommendation[] @relation("LawyerMatchingRecommendationRejectedBy")

  @@index([email])
}

model LawyerProfile {
  id                             String                   @id @default(cuid())
  userId                         String                   @unique
  registrationNumber             String?
  barAssociation                 String?
  officeName                     String?
  officeAddress                  String?
  officePhone                    String?
  websiteUrl                     String?
  specialtiesNote                String?
  verificationStatus             LawyerVerificationStatus @default(NOT_SUBMITTED)
  submittedAt                    DateTime?
  reviewedAt                     DateTime?
  reviewedById                   String?
  rejectionReason                String?
  /// 가입 시 디지털 무결 서약(허위 증빙 책임 안내) 접수 시각
  integrityAttestationAcceptedAt DateTime?
  /// 서약 문구 버전(로그·증빙)
  integrityAttestationVersion    String?
  /// 가입 요청 시 클라이언트 IP HMAC(SHA-256, salt) — 동일 출처 다중 가입 탐지 참고
  signupRiskIpFingerprint        String?
  /// User-Agent 앞 512자까지(원문 전체 미보관)
  signupRiskUserAgent            String?
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt

  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy            User?                        @relation("LawyerProfileReviewer", fields: [reviewedById], references: [id])
  verificationDocuments LawyerVerificationDocument[]

  @@index([verificationStatus])
  @@index([reviewedById])
  @@index([signupRiskIpFingerprint])
}

model LawyerVerificationDocument {
  id              String    @id @default(cuid())
  lawyerProfileId String
  type            String
  fileName        String
  /// **Legacy / 외부 URL 참조**(P4): 신규 저장 금지. 성격상 legacyExternalUrl; 컬럼명은 당분간 `fileUrl` 유지.
  fileUrl         String?
  /// Private bucket 객체 키(또는 provider 파일 ID). P3 에서 signed URL 발급 시 사용.
  storageKey      String?
  bucket          String?
  mimeType        String?
  sizeBytes       Int?
  checksum        String?
  uploadedAt      DateTime  @default(now())
  /// `fileUrl` → 객체 스토리지 이관 완료 시각(P4).
  migratedAt      DateTime?

  lawyerProfile LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)

  @@index([lawyerProfileId])
  @@index([storageKey])
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  email             String?
  emailVerified     Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model BulkActionJob {
  id            String    @id @default(cuid())
  action        String
  status        String
  actorId       String
  payloadJson   Json?
  targetIdsJson Json
  resultJson    Json?
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  canceledAt    DateTime?
  canceledById  String?
  cancelReason  String?

  retryOfJobId  String?
  lockedAt      DateTime?
  lockToken     String?
  lockExpiresAt DateTime?
  lockId        String?

  lastHeartbeatAt DateTime?
  heartbeatCount  Int       @default(0)

  priority       BulkActionJobPriority @default(NORMAL)
  queueGroup     String?
  concurrencyKey String?
  maxConcurrency Int                   @default(2)
  metadata       Json?

  totalItems     Int @default(0)
  completedItems Int @default(0)
  failedItems    Int @default(0)
  canceledItems  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  retryScheduledAt DateTime?

  actor         User            @relation("BulkActionJobActor", fields: [actorId], references: [id], onDelete: Cascade)
  canceledBy    User?           @relation("BulkActionJobCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)
  retryOfJob    BulkActionJob?  @relation("BulkActionJobRetry", fields: [retryOfJobId], references: [id], onDelete: SetNull)
  retryChildren BulkActionJob[] @relation("BulkActionJobRetry")

  items BulkActionJobItem[]

  schedules       BulkActionSchedule[]
  opsQueueTickets OpsQueueTicket[]

  @@index([status, createdAt])
  @@index([status, priority, createdAt])
  @@index([queueGroup, status, priority, createdAt])
  @@index([concurrencyKey, status, priority, createdAt])
  @@index([actorId, createdAt])
  @@index([retryOfJobId])
  @@index([lockExpiresAt])
  @@index([lastHeartbeatAt])
  @@index([retryScheduledAt])
}

model BulkActionJobItem {
  id    String        @id @default(cuid())
  jobId String
  job   BulkActionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  targetType String
  targetId   String
  action     String
  status     String
  sequence   Int    @default(0)

  errorCode    String?
  errorMessage String?
  errorPayload Json?

  failureCategory      BulkActionFailureCategory?
  failureTaxonomyCode  String?
  autoGuideCode        String?
  autoGuideLabel       String?
  autoGuideDescription String?
