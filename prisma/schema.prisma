/// 공부호 패킷 정의 — 본문은 `packetJson` 단일 블록(SSOT 동일 키). 인덱싱용 중복 필드만 컬럼으로 둠.
model GongbuhoPacket {
  id       String               @id @default(cuid())
  code     String
  version  String
  name     String
  domain   String
  caseType String?
  status   GongbuhoPacketStatus @default(DRAFT)

  packetJson Json

  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?

