  AUCTION_OR_PUBLIC_SALE
  LANDLORD_BANKRUPTCY_OR_REHABILITATION
  MULTIPLE_TENANT_DAMAGE
  DOUBLE_CONTRACT_OR_FALSE_CONTRACT
