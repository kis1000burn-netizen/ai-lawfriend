  BROKER_INVOLVEMENT_SUSPECTED
  OTHER
}

enum JeonseReportStatus {
  DRAFT_SUBMITTED
  REVIEW_READY
  DOCUMENTS_CHECKED
  REFERRED_TO_LAWYER
  CLOSED
}

model IllegalLendingReport {
  id            String                     @id @default(cuid())
  reporterType  IllegalLendingReporterType
  reporterName  String
  reporterPhone String
  reporterEmail String?
  uploadToken   String?                    @unique
  victimName    String?
  victimPhone   String?

  creditorName         String?
  creditorPhone        String?
  creditorBusinessName String?
  creditorAccount      String?
  creditorMemo         String?

  loanDate         DateTime?
  principalAmount  Int?
  receivedAmount   Int?
  repaidAmount     Int?
  demandedAmount   Int?
  interestRateMemo String?

  damageTypes       IllegalLendingDamageType[]
  collectionMethods String?
  damageSummary     String
  requestedHelp     String?

  evidenceSummary String?
  generatedReport String

  consentPrivacy       Boolean @default(false)
  consentNoLegalAdvice Boolean @default(false)

  status IllegalLendingReportStatus @default(DRAFT_SUBMITTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

