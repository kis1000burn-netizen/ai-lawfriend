  actor    User             @relation("UserParagraphVersions", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([documentId, versionGroupId])
  @@index([paragraphId, createdAt])
  @@index([caseId, documentId])
}

model DocumentParagraphRewriteHistory {
  id                String   @id @default(cuid())
  caseId            String
