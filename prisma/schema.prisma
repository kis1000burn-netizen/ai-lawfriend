  jobCode       String
  jobName       String
  status        CronJobStatus
  startedAt     DateTime
  finishedAt    DateTime?
  durationMs    Int?
  scannedCount  Int?
  affectedCount Int?
  message       String?
  errorStack    String?
  metaJson      Json?
  triggeredBy   String?
  retryOfRunId  String?

  createdAt DateTime @default(now())

  @@index([jobCode, createdAt])
  @@index([status, createdAt])
}

model Interview {
  id                 String          @id @default(cuid())
  caseId             String
  questionSetId      String?
  questionSetCode    String?
  questionSetVersion String?
  status             InterviewStatus @default(NOT_STARTED)
  startedAt          DateTime?
  completedAt        DateTime?
  answersJson        Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  voiceTranscripts VoiceTranscript[]

  @@index([caseId, status])
}

/// Phase 5-B — 음성 STT 결과 초안 저장. 인터뷰 답변(`Interview.answersJson`)에는 `CONFIRMED` 이후 API에서만 반영해야 한다.
model VoiceTranscript {
  id     String @id @default(cuid())
  caseId String
  /// `Interview.answersJson` 키 규약과 동일(예 공부호 `gongbuho.*` 포함).
  questionKey     String
  createdByUserId String
  interviewId     String?

  status VoiceTranscriptStatus @default(CAPTURED)

  draftText String? @db.Text

  /// 원본 오디오 옵션 — 기본 false (`docs/voice/VOICE_PRIVACY_AND_RETENTION_POLICY.md`).
  storeOriginalAudio      Boolean @default(false)
  originalAudioStorageKey String?

  /// Draft 상태 TTL 만료 목표 시각 앱 레이어가 설정한다(`VOICE_TRANSCRIPT_DRAFT_TTL_HOURS_DEFAULT`).
  expiresAt DateTime?

  confirmedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case        Case                       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy   User                       @relation("VoiceTranscriptCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  interview   Interview?                 @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  traces      VoiceInteractionTrace[]
  lawyerReviewCompletions VoiceLawyerReviewCompletion[]
  privacyOpsRequests      VoicePrivacyOpsRequest[]

  @@index([caseId, questionKey, status])
  @@index([caseId, status, expiresAt])
}

/// Phase 5-B Voice 사건 타임라인 append-only 이벤트(`docs/voice/VOICE_INTERVIEW_FLOW.md` §5).
model VoiceInteractionTrace {
  id                String                       @id @default(cuid())
  caseId            String
  voiceTranscriptId String
  event             VoiceInteractionTraceEvent
  payloadJson       Json?
  actorUserId       String?

  createdAt DateTime @default(now())

  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  voiceTranscript VoiceTranscript @relation(fields: [voiceTranscriptId], references: [id], onDelete: Cascade)
  actor           User?           @relation("VoiceInteractionTraceActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([voiceTranscriptId, createdAt])
}

/// Phase 5-H-UI-3 — 변호사 음성 transcript 검토 완료(질문 키별 · 확정 transcript ID에 바인딩).
model VoiceLawyerReviewCompletion {
  id                String   @id @default(cuid())
  caseId            String
  questionKey       String
  voiceTranscriptId String
  reviewedByUserId  String
  reviewedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt

  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  voiceTranscript VoiceTranscript @relation(fields: [voiceTranscriptId], references: [id], onDelete: Cascade)
  reviewedBy      User            @relation("VoiceLawyerReviewCompletionReviewer", fields: [reviewedByUserId], references: [id], onDelete: Cascade)

  @@unique([caseId, questionKey])
  @@index([caseId])
  @@index([voiceTranscriptId])
}

/// Phase 7-A — Voice transcript 삭제·정정·STT 민원 운영 티켓(본문 미저장 · 메타만).
model VoicePrivacyOpsRequest {
  id                String                         @id @default(cuid())
  caseId            String
  voiceTranscriptId String?
  requestType       VoicePrivacyOpsRequestType
  status            VoicePrivacyOpsRequestStatus   @default(OPEN)
