  ILLEGAL_COLLECTION
  THREAT_OR_INTIMIDATION
  CONTACT_FAMILY_OR_WORKPLACE
  PERSONAL_INFO_THREAT
  SEXUAL_IMAGE_THREAT
  UNREGISTERED_LENDER
  FALSE_OR_MISLEADING_CONTRACT
  OTHER
}

enum IllegalLendingReportStatus {
  DRAFT_SUBMITTED
  REVIEW_READY
  REFERRED_TO_LAWYER
  CLOSED
}

enum JeonseReporterType {
  TENANT
  FAMILY_OR_RELATED
  REPRESENTATIVE
  OTHER
}

enum JeonseDamageType {
