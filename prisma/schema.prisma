  fromStatus IllegalLendingReportStatus?
  toStatus   IllegalLendingReportStatus
  reason     String?
  actorId    String?
  actorName  String?
  actorRole  String?
  createdAt  DateTime                    @default(now())

  report IllegalLendingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([createdAt])
  @@index([toStatus])
}

model IllegalLendingReportAccessLog {
  id        String   @id @default(cuid())
  reportId  String
  action    String
  actorId   String?
  actorName String?
  actorRole String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  report IllegalLendingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([action])
  @@index([createdAt])
}

enum IllegalLendingAttachmentType {
  MESSAGE_CAPTURE
  CALL_RECORDING
  BANK_TRANSFER
  CONTRACT_OR_NOTE
  ID_OR_PERSONAL_INFO_REQUEST
  THREAT_EVIDENCE
  OTHER
}

enum IllegalLendingLawyerReviewStatus {
