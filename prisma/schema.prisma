generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  LAWYER
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

/// 변호사 **전문가 권한** 승인 상태 — `User.status`(계정 활성)와 분리한다.
enum LawyerVerificationStatus {
  NOT_SUBMITTED
  PENDING
  NEEDS_MORE_INFO
  APPROVED
  REJECTED
  SUSPENDED
}

enum AuthProvider {
  GOOGLE
  KAKAO
  NAVER
}

/// 공식서식 원천자료 제공기관
/// Phase 1에서는 실제 자동수집이 아니라 수동 등록/추적용 레지스트리로 사용한다.
enum LegalFormProvider {
  SCOURT
  POLICE
  SPO
  LAW_GO_KR
  KLAC
  INTERNAL_STANDARD
  OTHER
}

/// 공식서식 원천자료 상태
/// ACTIVE: 사용 가능, INACTIVE: 사용 중지, ARCHIVED: 보관
enum LegalFormSourceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

/// 앱 단일 기준: `src/lib/definitions/case-status.ts` 의 `CaseStatusEnum` 과 값·순서를 맞출 것.
/// (`npm run verify:canonical-sources` + 선택적 `POST /api/admin/verify-canonical-sources`)
enum CaseStatus {
  CREATED
  INTAKE_PENDING
  IN_INTERVIEW
  INTERVIEW_DONE
  DRAFTING
  REVIEW_PENDING
  APPROVED
  DELIVERED
  CLOSED
  HOLD
  REJECTED
  DELETED
}

enum InterviewStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  REOPENED
}

enum LegalDocumentType {
  STATEMENT
  OPINION
  CONSULT_NOTE
}

enum LegalDocumentStatus {
  NOT_CREATED
  DRAFT
  REVIEW_REQUIRED
  APPROVED
  LOCKED
  ARCHIVED
}

enum LegalParagraphStatus {
  DRAFT
  REVIEW_REQUIRED
  APPROVED
  LOCKED
}

enum QuestionSetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttachmentStatus {
  ACTIVE
  DELETED
}

/// 사건 첨부자료 분류 (FILE-1B) — CaseStatus·전이와 무관
enum CaseAttachmentCategory {
  EVIDENCE
  IDENTITY_DOC
  CONTRACT
  CORRESPONDENCE
  COURT_FILING
  FINANCIAL
  OTHER
}

enum CasePackageShareStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CasePackageShareMode {
  DESIGNATED_LAWYER
  PUBLIC_CODE_REQUEST
}

enum CasePackageAccessAction {
  VIEW
  DOWNLOAD
  DENIED
  EXPIRED
  REVOKED
}

enum SupplementRequestStatus {
  DRAFT
  SENT
  CLIENT_VIEWED
  CLIENT_RESPONDED
  UNDER_REVIEW
  NEEDS_MORE_INFO
  ACCEPTED
  CLOSED
  CANCELLED
  EXPIRED
}

enum SupplementRequestType {
  MISSING_FACT
  UNCLEAR_FACT
  ADDITIONAL_EVIDENCE
  DOCUMENT_CLARIFICATION
  PARTY_INFO
  TIMELINE_CONFIRMATION
  DAMAGE_DETAIL
  CONSENT_OR_NOTICE
  OTHER
}

enum SupplementAttachmentRole {
  EVIDENCE
  REFERENCE
  OTHER
}

enum SupplementRequestAuditActionType {
  CREATE
  UPDATE
  SEND
  CANCEL
  EXPIRE
  RESPOND
  START_REVIEW
  ACCEPT
  NEEDS_MORE_INFO
  CLOSE
  STATUS_LOG_VIEW
  AUDIT_LOG_VIEW
}

/// 공부호 패킷 수명 상태 — `docs/gongbuho/GONGBUHO_STANDARD.md` §3 Persistence
/// 적용 허용: `APPROVED`만 (`DRAFT`/`REVIEW`/`ARCHIVED`는 사건 매칭·적용 로직에서 제외)
enum GongbuhoPacketStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

/// Phase 5-B Voice intake draft — 문서 SSOT `docs/voice/VOICE_INTAKE_POLICY.md`.
enum VoiceTranscriptStatus {
  CAPTURED
  NEEDS_CONFIRMATION
  CONFIRMED
  REJECTED
}

/// Phase 5-B 사건 단위 Voice 이벤트 append — AuditLog 과밀 회피, 운영 추적 우선.
enum VoiceInteractionTraceEvent {
  VOICE_TRANSCRIPT_CREATED
  VOICE_TRANSCRIPT_CONFIRMED
  VOICE_TRANSCRIPT_REJECTED
  VOICE_INTERVIEW_ANSWER_BOUND
}

enum TimelineMemoType {
  USER_NOTE
  STAFF_NOTE
  SYSTEM
}

enum BulkActionJobPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum BulkActionFailureCategory {
  VALIDATION
  PERMISSION
  NOT_FOUND
  CONFLICT
  RATE_LIMIT
  LOCK
  TIMEOUT
  NETWORK
  INTERNAL
  UNKNOWN
}

enum OpsQueuePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OpsQueueBoardColumn {
  TRIAGE
  QUEUED
  WORKING
  BLOCKED
  DONE
}

enum TimelineExportFormat {
  CSV
  JSON
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String?
  name            String
  phone           String?
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  /// 일반 가입·소셜 이메일 검증 시각 — 미검증이면 null (MVP에서는 선택 적용).
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  cases               Case[]             @relation("UserCases")
  auditLogs           AuditLog[]         @relation("UserAuditLogs")
  uploadedAttachments CaseAttachment[]   @relation("UserUploadedCaseAttachments")
  timelineMemos       CaseTimelineMemo[] @relation("UserCaseTimelineMemos")
  assignedCases       CaseAssignment[]   @relation("UserAssignedCases")
  createdAssignments  CaseAssignment[]   @relation("UserCreatedAssignments")

  createdAlertRules           AlertRule[]                       @relation("AlertRuleCreatedBy")
  updatedAlertRules           AlertRule[]                       @relation("AlertRuleUpdatedBy")
  alertEventsActed            AlertEvent[]                      @relation("AlertEventActor")
  alertEventsAcknowledged     AlertEvent[]                      @relation("AlertEventAcknowledgedBy")
  alertEventsIgnored          AlertEvent[]                      @relation("AlertEventIgnoredBy")
  alertEventsResolved         AlertEvent[]                      @relation("AlertEventResolvedBy")
  alertEventsAssigned         AlertEvent[]                      @relation("AlertAssignee")
  escalationsReleased         AlertEscalation[]                 @relation("EscalationReleasedBy")
  adminNotifications          AdminNotification[]
  alertBoardFilterPresets     AlertBoardFilterPreset[]
  bulkActionJobs              BulkActionJob[]                   @relation("BulkActionJobActor")
  canceledBulkActionJobs      BulkActionJob[]                   @relation("BulkActionJobCanceledBy")
  opsQueueTicketsAssigned     OpsQueueTicket[]                  @relation("OpsQueueTicketAssignee")
  timelineExportLogs          TimelineExportLog[]
  paragraphRewriteHistories   DocumentParagraphRewriteHistory[]
  documentParagraphVersions   DocumentParagraphVersion[]        @relation("UserParagraphVersions")
  ownedCasePackageShares      CasePackageShare[]                @relation("CasePackageShareOwner")
  lawyerCasePackageShares     CasePackageShare[]                @relation("CasePackageShareLawyer")
  casePackageAccessLogs       CasePackageAccessLog[]            @relation("CasePackageAccessLogActor")
  requestedSupplementRequests SupplementRequest[]               @relation("SupplementRequestRequester")
  targetSupplementRequests    SupplementRequest[]               @relation("SupplementRequestTarget")
  supplementResponses         SupplementResponse[]              @relation("SupplementResponseResponder")
  supplementRequestStatusLogs SupplementRequestStatusLog[]      @relation("SupplementRequestStatusLogActor")
  supplementRequestAuditLogs  SupplementRequestAuditLog[]       @relation("SupplementRequestAuditLogActor")
  authAccounts                AuthAccount[]
  lawyerProfile               LawyerProfile?
  lawyerProfilesReviewed      LawyerProfile[]                   @relation("LawyerProfileReviewer")
  gongbuhoPacketsCreated      GongbuhoPacket[]                  @relation("GongbuhoPacketCreatedBy")
  gongbuhoPacketsApproved     GongbuhoPacket[]                  @relation("GongbuhoPacketApprovedBy")
  voiceTranscriptsCreated     VoiceTranscript[]                 @relation("VoiceTranscriptCreatedBy")
  voiceInteractionTracesActor VoiceInteractionTrace[]           @relation("VoiceInteractionTraceActor")

  @@index([email])
}

model LawyerProfile {
  id                             String                   @id @default(cuid())
  userId                         String                   @unique
  registrationNumber             String?
  barAssociation                 String?
  officeName                     String?
  officeAddress                  String?
  officePhone                    String?
  websiteUrl                     String?
  specialtiesNote                String?
  verificationStatus             LawyerVerificationStatus @default(NOT_SUBMITTED)
  submittedAt                    DateTime?
  reviewedAt                     DateTime?
  reviewedById                   String?
  rejectionReason                String?
  /// 가입 시 디지털 무결 서약(허위 증빙 책임 안내) 접수 시각
  integrityAttestationAcceptedAt DateTime?
  /// 서약 문구 버전(로그·증빙)
  integrityAttestationVersion    String?
  /// 가입 요청 시 클라이언트 IP HMAC(SHA-256, salt) — 동일 출처 다중 가입 탐지 참고
  signupRiskIpFingerprint        String?
  /// User-Agent 앞 512자까지(원문 전체 미보관)
  signupRiskUserAgent            String?
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt

  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy            User?                        @relation("LawyerProfileReviewer", fields: [reviewedById], references: [id])
  verificationDocuments LawyerVerificationDocument[]

  @@index([verificationStatus])
  @@index([reviewedById])
  @@index([signupRiskIpFingerprint])
}

model LawyerVerificationDocument {
  id              String    @id @default(cuid())
  lawyerProfileId String
  type            String
  fileName        String
  /// **Legacy / 외부 URL 참조**(P4): 신규 저장 금지. 성격상 legacyExternalUrl; 컬럼명은 당분간 `fileUrl` 유지.
  fileUrl         String?
  /// Private bucket 객체 키(또는 provider 파일 ID). P3 에서 signed URL 발급 시 사용.
  storageKey      String?
  bucket          String?
  mimeType        String?
  sizeBytes       Int?
  checksum        String?
  uploadedAt      DateTime  @default(now())
  /// `fileUrl` → 객체 스토리지 이관 완료 시각(P4).
  migratedAt      DateTime?

  lawyerProfile LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)

  @@index([lawyerProfileId])
  @@index([storageKey])
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  email             String?
  emailVerified     Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model BulkActionJob {
  id            String    @id @default(cuid())
  action        String
  status        String
  actorId       String
  payloadJson   Json?
  targetIdsJson Json
  resultJson    Json?
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  canceledAt    DateTime?
  canceledById  String?
  cancelReason  String?

  retryOfJobId  String?
  lockedAt      DateTime?
  lockToken     String?
  lockExpiresAt DateTime?
  lockId        String?

  lastHeartbeatAt DateTime?
  heartbeatCount  Int       @default(0)

  priority       BulkActionJobPriority @default(NORMAL)
  queueGroup     String?
  concurrencyKey String?
  maxConcurrency Int                   @default(2)
  metadata       Json?

  totalItems     Int @default(0)
  completedItems Int @default(0)
  failedItems    Int @default(0)
  canceledItems  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  retryScheduledAt DateTime?

  actor         User            @relation("BulkActionJobActor", fields: [actorId], references: [id], onDelete: Cascade)
  canceledBy    User?           @relation("BulkActionJobCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)
  retryOfJob    BulkActionJob?  @relation("BulkActionJobRetry", fields: [retryOfJobId], references: [id], onDelete: SetNull)
  retryChildren BulkActionJob[] @relation("BulkActionJobRetry")

  items BulkActionJobItem[]

  schedules       BulkActionSchedule[]
  opsQueueTickets OpsQueueTicket[]

  @@index([status, createdAt])
  @@index([status, priority, createdAt])
  @@index([queueGroup, status, priority, createdAt])
  @@index([concurrencyKey, status, priority, createdAt])
  @@index([actorId, createdAt])
  @@index([retryOfJobId])
  @@index([lockExpiresAt])
  @@index([lastHeartbeatAt])
  @@index([retryScheduledAt])
}

model BulkActionJobItem {
  id    String        @id @default(cuid())
  jobId String
  job   BulkActionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  targetType String
  targetId   String
  action     String
  status     String
  sequence   Int    @default(0)

  errorCode    String?
  errorMessage String?
  errorPayload Json?

  failureCategory      BulkActionFailureCategory?
  failureTaxonomyCode  String?
  autoGuideCode        String?
  autoGuideLabel       String?
  autoGuideDescription String?
  retryable            Boolean                    @default(false)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  metadata Json?

  @@index([jobId, status])
  @@index([jobId, failureCategory])
  @@index([jobId, failureTaxonomyCode])
  @@index([targetType, targetId])
}

model BulkActionSchedule {
  id                String   @id @default(cuid())
  sourceJobId       String
  taxonomy          String
  bulkVariant       String
  status            String   @default("PENDING")
  scheduledFor      DateTime
  note              String?
  dedupeKey         String   @unique
  createdRetryJobId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sourceJob BulkActionJob @relation(fields: [sourceJobId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([sourceJobId, taxonomy])
}

model OpsQueueTicket {
  id                String              @id @default(cuid())
  sourceJobId       String
  caseId            String?
  taxonomy          String
  bulkVariant       String
  status            String              @default("OPEN")
  title             String
  description       String?
  severity          String              @default("MEDIUM")
  priority          OpsQueuePriority    @default(NORMAL)
  dedupeKey         String              @unique
  assigneeUserId    String?
  metadata          Json?
  dueAt             DateTime?
  slaMinutes        Int?
  overdueNotifiedAt DateTime?
  slaLastCheckedAt  DateTime?
  boardColumn       OpsQueueBoardColumn @default(TRIAGE)
  boardOrder        Int                 @default(0)
  retryScheduledAt  DateTime?
  retrySourceJobId  String?
  queueGroup        String?
  concurrencyKey    String?
  maxConcurrency    Int?
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  sourceJob BulkActionJob @relation(fields: [sourceJobId], references: [id], onDelete: Cascade)
  assignee  User?         @relation("OpsQueueTicketAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  case      Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([status, dueAt])
  @@index([assigneeUserId, status])
  @@index([boardColumn, boardOrder])
  @@index([retryScheduledAt])
  @@index([overdueNotifiedAt])
  @@index([status, createdAt])
  @@index([sourceJobId, taxonomy])
}

model TimelineExportLog {
  id            String               @id @default(cuid())
  requestedById String
  caseId        String?
  format        TimelineExportFormat
  itemCount     Int
  createdAt     DateTime             @default(now())

  requestedBy User @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([requestedById, createdAt])
}

model OpsQueueSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  jsonValue Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkerHeartbeat {
  id              String   @id @default(cuid())
  workerKey       String   @unique
  workerType      String
  hostname        String?
  pid             Int?
  currentJobId    String?
  status          String   @default("IDLE")
  metadata        Json?
  lastHeartbeatAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workerType, lastHeartbeatAt])
  @@index([status, lastHeartbeatAt])
}

model Case {
  id                   String     @id @default(cuid())
  ownerUserId          String
  title                String
  description          String?
  category             String?
  opponentName         String?
  courtName            String?
  incidentDate         DateTime?
  status               CaseStatus @default(CREATED)
  assignedLawyerUserId String?
  assignedStaffUserId  String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  owner                      User                              @relation("UserCases", fields: [ownerUserId], references: [id], onDelete: Cascade)
  attachments                CaseAttachment[]
  timelineMemos              CaseTimelineMemo[]
  assignments                CaseAssignment[]
  opsQueueTickets            OpsQueueTicket[]
  paragraphRewriteHistories  DocumentParagraphRewriteHistory[]
  caseTimelineMemoParagraphs CaseTimelineMemoParagraph[]
  documentApprovalReviews    DocumentApprovalReview[]
  documentParagraphVersions  DocumentParagraphVersion[]
  interviews                 Interview[]
  legalDocuments             LegalDocument[]
  caseTimelineEvents         CaseTimelineEvent[]
  casePackageShares          CasePackageShare[]
  supplementRequests         SupplementRequest[]
  gongbuhoTraces             GongbuhoTrace[]
  voiceTranscripts           VoiceTranscript[]
  voiceInteractionTraces     VoiceInteractionTrace[]

  /// 사건 인터뷰에 사용할 질문셋(선택). 미지정 시 전역 활성 단일 QuestionSet 규약 유지(Phase 3-D).
  questionSetId               String?
  interviewQuestionSet       QuestionSet? @relation("CaseInterviewQuestionSet", fields: [questionSetId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, status, createdAt])
  @@index([status, createdAt])
  @@index([questionSetId])
  @@index([assignedLawyerUserId])
  @@index([assignedStaffUserId])
}

model CasePackageShare {
  id           String  @id @default(cuid())
  caseId       String
  ownerUserId  String
  lawyerUserId String?

  publicCode      String  @unique
  accessTokenHash String?
  optionalPinHash String?

  shareMode CasePackageShareMode   @default(DESIGNATED_LAWYER)
  status    CasePackageShareStatus @default(ACTIVE)

  allowSummary            Boolean @default(true)
  allowInterview          Boolean @default(true)
  allowAttachmentList     Boolean @default(true)
  allowAttachmentDownload Boolean @default(false)
  allowDocumentDraft      Boolean @default(true)
  allowDocumentPdf        Boolean @default(false)
  allowPackagePdf         Boolean @default(false)
  allowClientContact      Boolean @default(false)
  allowOpponentDetail     Boolean @default(false)

  consentText  String    @db.Text
  consentedAt  DateTime
  expiresAt    DateTime?
  revokedAt    DateTime?
  revokeReason String?

  /// 공유 생성 시점의 사건 패키지 전체 스냅샷(JSON). 변호사 열람·PDF 등은 변경 후에도 동일 버전 유지용.
  snapshotJson   Json?
  /// `snapshotJson` UTF-8 JSON 직렬화 기준 SHA-256 무결성(내부 감사·오염 탐지)
  snapshotSha256 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case   Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  owner  User  @relation("CasePackageShareOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  lawyer User? @relation("CasePackageShareLawyer", fields: [lawyerUserId], references: [id], onDelete: SetNull)

  accessLogs CasePackageAccessLog[]

  @@index([caseId, status])
  @@index([ownerUserId, createdAt])
  @@index([lawyerUserId, createdAt])
  @@index([publicCode])
}

model CasePackageAccessLog {
  id            String                  @id @default(cuid())
  shareId       String
  caseId        String
  actorUserId   String?
  action        CasePackageAccessAction
  targetType    String
  targetId      String?
  ip            String?
  userAgent     String?
  resultMessage String?
  createdAt     DateTime                @default(now())

  share CasePackageShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  actor User?            @relation("CasePackageAccessLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([shareId, createdAt])
  @@index([caseId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model SupplementRequest {
  id              String                  @id @default(cuid())
  caseId          String
  requesterUserId String
  targetUserId    String
  status          SupplementRequestStatus @default(DRAFT)
  requestType     SupplementRequestType
  title           String
  description     String                  @db.Text
  dueAt           DateTime?
  sentAt          DateTime?
  clientViewedAt  DateTime?
  lastRespondedAt DateTime?
  acceptedAt      DateTime?
  closedAt        DateTime?
  cancelledAt     DateTime?
  expiredAt       DateTime?
  revisionRound   Int                     @default(0)
  isDeleted       Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  case      Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  requester User @relation("SupplementRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  target    User @relation("SupplementRequestTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  items      SupplementRequestItem[]
  responses  SupplementResponse[]
  statusLogs SupplementRequestStatusLog[]
  auditLogs  SupplementRequestAuditLog[]

  @@index([caseId, status, createdAt])
  @@index([requesterUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([isDeleted, updatedAt])
}

model SupplementRequestItem {
  id             String                @id @default(cuid())
  requestId      String
  itemType       SupplementRequestType
  itemLabel      String
  itemPrompt     String                @db.Text
  isRequired     Boolean               @default(true)
  sortOrder      Int                   @default(0)
  expectedFormat String?
  maxLength      Int?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  request SupplementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  responses SupplementResponse[]

  @@index([requestId, sortOrder])
}

model SupplementResponse {
  id                 String   @id @default(cuid())
  requestId          String
  requestItemId      String?
  responderUserId    String
  responderRole      UserRole
  responseText       String?  @db.Text
  responseJson       Json?
  submittedAt        DateTime @default(now())
  revisionRound      Int      @default(0)
  isAcceptedSnapshot Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  request     SupplementRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestItem SupplementRequestItem? @relation(fields: [requestItemId], references: [id], onDelete: SetNull)
  responder   User                   @relation("SupplementResponseResponder", fields: [responderUserId], references: [id], onDelete: Cascade)

  attachments SupplementResponseAttachment[]

  @@index([requestId, submittedAt])
  @@index([responderUserId, submittedAt])
}

model SupplementResponseAttachment {
  id               String                   @id @default(cuid())
  responseId       String
  caseAttachmentId String
  attachmentRole   SupplementAttachmentRole @default(EVIDENCE)
  note             String?
  uploadedAt       DateTime                 @default(now())
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  response       SupplementResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
