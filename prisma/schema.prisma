  supportedDocumentTypes Json              @default("[]")
  visibleToRoles         Json              @default("[]")
  /// 카탈로그(섹션) Zod 구조. 인터뷰 런타임/완료 필수는 getActiveQuestionSet().questions(EVIDENCE-330).
  definitionJson         Json?
  publishedAt            DateTime?
  archivedAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  caseInterviewBindings Case[] @relation("CaseInterviewQuestionSet")

  @@index([isActive, updatedAt])
  @@index([createdAt])
  @@index([catalogStatus])
}

model LegalFormSource {
  id               String                @id @default(cuid())
  provider         LegalFormProvider
  sourceName       String
  sourceUrl        String
  documentType     String
  category         String?
  officialFormCode String?
  fileName         String?
  fileMimeType     String?
  fileHash         String?
  storageKey       String?
  licenseNote      String?
  downloadedAt     DateTime?
  effectiveDate    DateTime?
  parsedText       String?               @db.Text
  status           LegalFormSourceStatus @default(ACTIVE)
  memo             String?               @db.Text
  createdByUserId  String?
  updatedByUserId  String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  templates DocumentTemplate[]

  @@index([provider, status])
  @@index([documentType, status])
  @@index([sourceName])
  @@index([fileHash])
  @@index([createdAt])
}

/// 문서 템플릿(섹션/문단 정의) — definitionJson에 DocumentTemplateDefinition 저장
/// catalogStatus는 질문셋과 동일 enum(`QuestionSetStatus`)을 재사용한다.
model DocumentTemplate {
  id             String            @id @default(cuid())
  code           String
  version        String
  type           LegalDocumentType
  title          String
  description    String?
  definitionJson Json
  /// 공식서식 출처 연결. 내부 표준 템플릿이면 sourceProvider = INTERNAL_STANDARD, sourceId = null 허용.
  sourceId       String?
  sourceProvider LegalFormProvider @default(INTERNAL_STANDARD)
  sourceUrl      String?
  sourceHash     String?
  sourceNote     String?
  catalogStatus  QuestionSetStatus @default(DRAFT)
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  source LegalFormSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([code, version])
  @@index([type])
  @@index([catalogStatus])
  @@index([sourceId])
  @@index([sourceProvider])
}

/// Phase 15-A — Client portal access (case owner + invited clients)
model CaseClientPortalAccess {
  id              String                       @id @default(cuid())
  caseId          String
  clientUserId    String
  invitedByUserId String?
  accessStatus    CaseClientPortalAccessStatus @default(ACTIVE)
  lastAccessedAt  DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  case      Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  client    User  @relation("CaseClientPortalAccessClient", fields: [clientUserId], references: [id], onDelete: Cascade)
  invitedBy User? @relation("CaseClientPortalAccessInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([caseId, clientUserId])
  @@index([clientUserId, accessStatus])
}

/// Phase 15-A — Client submission bundle (answer + files, not confirmed case material until ACCEPTED)
model ClientSubmission {
  id                  String               @id @default(cuid())
  caseId              String
  supplementRequestId String?
  submittedByUserId   String
  reviewedByUserId    String?
  kind                ClientSubmissionKind @default(SUPPLEMENT)
  status              ClientSubmissionStatus @default(DRAFT)
  message             String?              @db.Text
  reviewMemo          String?              @db.Text
  submittedAt         DateTime?
  receivedAt          DateTime?
  reviewedAt          DateTime?
  acceptedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  case              Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  supplementRequest SupplementRequest? @relation(fields: [supplementRequestId], references: [id], onDelete: SetNull)
  submitter         User               @relation("ClientSubmissionSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  reviewer          User?              @relation("ClientSubmissionReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  files             ClientSubmissionFile[]

  @@index([caseId, status, createdAt])
  @@index([supplementRequestId, status])
  @@index([submittedByUserId, createdAt])
}

model ClientSubmissionFile {
  id               String   @id @default(cuid())
  submissionId     String
  uploadedFileId   String
  originalFileName String
  fileType         String?
  description      String?  @db.Text
  sharedWithLawyer Boolean  @default(true)
  createdAt        DateTime @default(now())

  submission   ClientSubmission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  uploadedFile LitigationUploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@index([uploadedFileId])
}

/// Phase 15-A — Case-scoped secure conversation thread
model CaseConversationThread {
  id                  String                     @id @default(cuid())
  caseId              String
  threadType          CaseConversationThreadType @default(GENERAL)
  supplementRequestId String?
  title               String?
  lastMessageAt       DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  case              Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  supplementRequest SupplementRequest? @relation(fields: [supplementRequestId], references: [id], onDelete: SetNull)
  messages          CaseConversationMessage[]

  @@index([caseId, lastMessageAt])
  @@index([supplementRequestId])
}

model CaseConversationMessage {
  id              String   @id @default(cuid())
  threadId        String
  caseId          String
  senderUserId    String
  senderRole      UserRole
  body            String   @db.Text
  attachmentIds   Json?
  readByJson      Json?
  isPinnedForRecord Boolean @default(false)
  createdAt       DateTime @default(now())

  thread CaseConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  case   Case                   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sender User                   @relation("CaseConversationMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  attachments CaseMessageAttachment[]

  @@index([threadId, createdAt])
  @@index([caseId, createdAt])
  @@index([senderUserId, createdAt])
}

/// Phase 15-A — Lawyer-shared document for client portal
model CaseSharedDocument {
  id                    String                   @id @default(cuid())
  caseId                String
  documentId            String
  sharedByUserId        String
  sharedWithClientUserId String
  shareStatus           CaseSharedDocumentStatus @default(ACTIVE)
  sharedAt              DateTime                 @default(now())
  expiresAt             DateTime?
  firstViewedAt         DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  case           Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document       LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sharedBy       User          @relation("CaseSharedDocumentSharer", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWithClient User        @relation("CaseSharedDocumentRecipient", fields: [sharedWithClientUserId], references: [id], onDelete: Cascade)
  deliveries     CaseDocumentDelivery[]

  @@index([caseId, shareStatus, sharedAt])
  @@index([sharedWithClientUserId, shareStatus])
}

/// Phase 15-F — Secure document delivery (login-gated link, no raw file in external channel)
model CaseDocumentDelivery {
  id                    String                      @id @default(cuid())
  caseId                String
  sharedDocumentId      String
  documentId            String
  recipientClientUserId String
  deliveryChannel       CaseDocumentDeliveryChannel
  deliveryStatus        CaseDocumentDeliveryStatus  @default(PENDING)
  secureLinkTokenHash   String
  tokenExpiresAt        DateTime
  sentAt                DateTime?
  viewedAt              DateTime?
  failureReason         String?                     @db.Text
  createdByUserId       String
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  case             Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sharedDocument   CaseSharedDocument @relation(fields: [sharedDocumentId], references: [id], onDelete: Cascade)
  document         LegalDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipientClient  User               @relation("CaseDocumentDeliveryRecipient", fields: [recipientClientUserId], references: [id], onDelete: Cascade)
  createdBy        User               @relation("CaseDocumentDeliveryCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  externalMessages ExternalMessageLog[]

  @@index([caseId, deliveryStatus])
  @@index([sharedDocumentId, deliveryChannel])
  @@index([recipientClientUserId, deliveryStatus])
}

/// Phase 15-F — External channel dispatch log (Kakao Alimtalk stub / email / SMS)
model ExternalMessageLog {
  id                 String                    @id @default(cuid())
  caseId             String
  recipientUserId    String
  deliveryId         String?
  channel            CaseDocumentDeliveryChannel
  provider           String                    @default("STUB")
  templateCode       String?
  payloadSummaryJson Json
  status             ExternalMessageStatus     @default(PENDING)
  failureReason      String?                   @db.Text
  sentAt             DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  case      Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  recipient User                  @relation("ExternalMessageLogRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  delivery  CaseDocumentDelivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)

  @@index([caseId, channel, status])
  @@index([recipientUserId, createdAt])
  @@index([deliveryId])
}

/// Phase 15-C — Chat message file attachment (non-confirmed until lawyer adopts)
model CaseMessageAttachment {
  id               String   @id @default(cuid())
  messageId        String
  uploadedFileId   String
  originalFileName String
  createdAt        DateTime @default(now())

  message      CaseConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedFile LitigationUploadedFile  @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([uploadedFileId])
}

/// Phase 18-A — Platform retry queue (failed jobs persist; operator-approved safe retry).
enum RetryJobSourceType {
  CRON
  EXTERNAL_MESSAGE
  BULK_ACTION
  DOCUMENT_PIPELINE
  AI_GOVERNANCE
  AI_CALL
  MANUAL
}

enum RetryJobStatus {
  FAILED
  PENDING_RETRY
  RETRYING
  SUCCEEDED
  CANCELED
  EXHAUSTED
}

enum RetryJobSafetyClass {
  SAFE_AUTO
  OPERATOR_APPROVAL
  BLOCKED
}

model RetryJob {
  id               String              @id @default(cuid())
  sourceType       RetryJobSourceType
  sourceRefId      String?
  jobCode          String
  caseId           String?
  status           RetryJobStatus      @default(FAILED)
  safetyClass      RetryJobSafetyClass @default(OPERATOR_APPROVAL)
  retryable        Boolean             @default(false)
  attemptCount     Int                 @default(0)
  maxAttempts      Int                 @default(3)
  failureReason    String?             @db.Text
  failurePayload   Json?
  lastAttemptAt    DateTime?
  nextRetryAt      DateTime?
  resolvedAt       DateTime?
  resolvedByUserId String?
  operatorNote     String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  case       Case? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("RetryJobResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceRefId])
  @@index([status, createdAt])
  @@index([caseId, createdAt])
  @@index([jobCode, status])
}

/// Phase 18-C — Document pipeline stage failure & safe resume (no re-upload · no overwrite).
enum DocumentPipelineStage {
  UPLOAD
  EXTRACT
  CLASSIFY
  ANALYZE
  OPPONENT_BRIEF
}

enum DocumentPipelineJobStatus {
  FAILED
  PENDING_RECOVERY
  RECOVERING
  SUCCEEDED
  BLOCKED
  EXHAUSTED
}

model DocumentPipelineJob {
  id                     String                    @id @default(cuid())
  uploadedFileId         String
  caseId                 String
  failedStage            DocumentPipelineStage
  resumeFromStage        DocumentPipelineStage
  status                 DocumentPipelineJobStatus @default(FAILED)
  failureReason          String?                   @db.Text
  failurePayload         Json?
  completedStagesJson    Json?
  lawyerReviewLocked     Boolean                   @default(false)
  clientDisclosureLocked Boolean                   @default(false)
  duplicateGuardKey      String
  attemptCount           Int                       @default(0)
  maxAttempts            Int                       @default(3)
  resolvedAt             DateTime?
  resolvedByUserId       String?
  operatorNote           String?                   @db.Text
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  uploadedFile LitigationUploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  case         Case                   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  resolvedBy   User?                  @relation("DocumentPipelineJobResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([duplicateGuardKey])
  @@index([uploadedFileId, failedStage])
  @@index([caseId, status, createdAt])
  @@index([status, createdAt])
}

/// Phase 49-A — Legal Reliability Risk Radar → Supplement Action Candidate.
model LegalReliabilityActionCandidate {
  id        String   @id @default(cuid())
  caseId    String
  tenantId  String?

  sourcePhase String
  sourceType  String
  sourceId    String

  actionType String
  status     String

  riskType   String
  severity   String

  lawyerFacingTitle  String
  lawyerFacingReason String @db.Text

  proposedClientRequestTitle String
  proposedClientRequestBody  String @db.Text

  clientVisibleByDefault      Boolean @default(false)
  prohibitedClientTextRemoved Boolean @default(true)
  requiresLawyerApproval      Boolean @default(true)

  linkedClaimIds    Json
  linkedEvidenceIds Json
  linkedJudgmentIds Json

  supplementRequestId String?
  createdByUserId     String?
  approvedByUserId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  decisionLedgers LegalReliabilityActionDecisionLedger[]
  actionOperation LegalReliabilityActionOperation?

  @@index([caseId, status, createdAt])
  @@index([sourceId, caseId])
  @@index([supplementRequestId])
}

/// Phase 49-A — Lawyer decision ledger for supplement action candidates.
model LegalReliabilityActionDecisionLedger {
  id          String   @id @default(cuid())
  caseId      String
  tenantId    String?

  actionCandidateId String
  decisionType      String

  decidedByUserId String
  decidedByRole   String

  beforeClientRequestBody String? @db.Text
  afterClientRequestBody  String? @db.Text

  rejectionReason String? @db.Text
  deferReason     String? @db.Text

  sourceRiskRadarSignalId String?

  linkedClaimIds    Json
  linkedEvidenceIds Json
  linkedJudgmentIds Json

  createdAt DateTime @default(now())

  case              Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actionCandidate   LegalReliabilityActionCandidate @relation(fields: [actionCandidateId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([actionCandidateId, createdAt])
}

/// Phase 50-A — Legal Reliability Action Operations Queue.
model LegalReliabilityActionOperation {
  id        String   @id @default(cuid())
  caseId    String
  tenantId  String?

  sourcePhase             String
  sourceActionCandidateId String @unique
  supplementRequestId     String?

  operationType String
  status        String
  priority      String @default("MEDIUM")

  assignedToUserId String?
  assignedByUserId String?
  assignedAt       DateTime?
  dueAt            DateTime?

  slaStatus    String   @default("NO_DUE_DATE")
  slaCheckedAt DateTime?

  clientResponseReceivedAt DateTime?
  clientResponseSummary     String? @db.Text
  lawyerReviewedAt         DateTime?
  completedAt              DateTime?

  linkedClientSubmissionIds Json @default("[]")
  linkedUploadedFileIds     Json @default("[]")
  linkedEvidenceIntakeIds   Json @default("[]")
  evidenceIntakeStatus      String @default("NONE")
  reviewHandoffJson         Json?

  completionResult String?

  lawyerFacingTitle String
  sourceLabel       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case              Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sourceActionCandidate LegalReliabilityActionCandidate @relation(fields: [sourceActionCandidateId], references: [id], onDelete: Cascade)

  @@index([caseId, status, createdAt])
  @@index([supplementRequestId])
  @@index([assignedToUserId])
  @@index([slaStatus])
}
