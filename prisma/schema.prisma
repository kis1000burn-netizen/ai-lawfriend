enum AlertRuleType {
  ROLE_SPIKE
  NIGHT_ACTIVITY
  ACTION_POLICY
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertEventStatus {
  OPEN
  ACKNOWLEDGED
  IGNORED
  RESOLVED
}

enum NotificationType {
  ALERT_EVENT
  SYSTEM
  BULK_JOB_SUCCESS
  BULK_JOB_PARTIAL_SUCCESS
  BULK_JOB_FAILED
  BULK_JOB_CANCELED
}

enum AlertSlaState {
  ON_TRACK
  DUE_SOON
  OVERDUE
}

enum AlertSlaWarningStatus {
  OPEN
  CLEARED
}

enum AlertEscalationLevel {
  NONE
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum AlertEscalationStatus {
  PENDING
  SENT
  CLEARED
}

enum AlertEscalationTargetGroup {
  ADMINS
  LAWYERS
  ASSIGNEE
  CUSTOM_USERS
}

model AlertRule {
  id                     String                       @id @default(cuid())
  name                   String
  code                   String                       @unique
  type                   AlertRuleType
  enabled                Boolean                      @default(true)
  severity               AlertSeverity                @default(WARNING)
  configJson             Json
  description            String?
  slaHours               Int?
  dueSoonHours           Int?
  escalationLevel1Hours  Int?
  escalationLevel2Hours  Int?
  escalationLevel3Hours  Int?
  escalationTargetGroups AlertEscalationTargetGroup[] @default([ADMINS])
  escalationUserIdsJson  Json?
  createdByUserId        String?
  updatedByUserId        String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  createdByUser User?        @relation("AlertRuleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?        @relation("AlertRuleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  events        AlertEvent[]

  @@index([enabled, type])
  @@index([createdAt])
}

model AlertEvent {
  id               String               @id @default(cuid())
  ruleId           String?
  status           AlertEventStatus     @default(OPEN)
  severity         AlertSeverity
  title            String
  message          String
  fingerprint      String               @unique
  entityType       String?
  entityId         String?
  actorUserId      String?
  detectedAt       DateTime             @default(now())
  acknowledgedAt   DateTime?
  acknowledgedById String?
  ignoredAt        DateTime?
  ignoredById      String?
  resolvedAt       DateTime?
  resolvedById     String?
  payloadJson      Json
  assigneeUserId   String?
  dueAt            DateTime?
  slaState         AlertSlaState        @default(ON_TRACK)
  slaHours         Int?
  dueSoonHours     Int?
  escalationLevel  AlertEscalationLevel @default(NONE)
  boardOrder       Int                  @default(0)

  rule           AlertRule?          @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  actorUser      User?               @relation("AlertEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  assigneeUser   User?               @relation("AlertAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  acknowledgedBy User?               @relation("AlertEventAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  ignoredBy      User?               @relation("AlertEventIgnoredBy", fields: [ignoredById], references: [id], onDelete: SetNull)
  resolvedBy     User?               @relation("AlertEventResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  notifications  AdminNotification[]
  timelineMemos  CaseTimelineMemo[]
  slaWarnings    AlertSlaWarning[]
  escalations    AlertEscalation[]

  @@index([status, detectedAt])
  @@index([severity, detectedAt])
  @@index([entityType, entityId])
  @@index([actorUserId, detectedAt])
  @@index([assigneeUserId, status])
  @@index([dueAt, status])
  @@index([slaState, status])
  @@index([status, escalationLevel])
  @@index([status, boardOrder])
}

model AlertEscalation {
  id               String                @id @default(cuid())
  alertEventId     String
  level            AlertEscalationLevel
  status           AlertEscalationStatus @default(PENDING)
  message          String
  createdAt        DateTime              @default(now())
  sentAt           DateTime?
  clearedAt        DateTime?
  releaseReason    String?
  releasedByUserId String?

  alertEvent AlertEvent @relation(fields: [alertEventId], references: [id], onDelete: Cascade)
  releasedBy User?      @relation("EscalationReleasedBy", fields: [releasedByUserId], references: [id], onDelete: SetNull)

  @@unique([alertEventId, level, status])
  @@index([status, createdAt])
}

model AlertSlaWarning {
  id           String                @id @default(cuid())
  alertEventId String
  status       AlertSlaWarningStatus @default(OPEN)
  warningType  String
  message      String
  createdAt    DateTime              @default(now())
  clearedAt    DateTime?

  alertEvent AlertEvent @relation(fields: [alertEventId], references: [id], onDelete: Cascade)

  @@unique([alertEventId, warningType, status])
  @@index([status, createdAt])
  @@index([warningType, createdAt])
}

model AdminNotification {
  id           String           @id @default(cuid())
  type         NotificationType @default(ALERT_EVENT)
  title        String
  body         String
  readAt       DateTime?
  targetHref   String?
  metaJson     Json?
  userId       String
  alertEventId String?
  createdAt    DateTime         @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertEvent AlertEvent? @relation(fields: [alertEventId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([alertEventId])
}

enum CronJobStatus {
  RUNNING
  SUCCESS
  FAILED
}

model AlertBoardFilterPreset {
  id        String  @id @default(cuid())
  name      String
  userId    String
  isDefault Boolean @default(false)
  scope     String  @default("PRIVATE")

  status          String?
  severity        String?
  ruleCode        String?
  escalationLevel Int?
  assigneeUserId  String?
  dueFrom         DateTime?
  dueTo           DateTime?
  q               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model CronJobExecutionLog {
  id            String        @id @default(cuid())
  jobCode       String
  jobName       String
  status        CronJobStatus
  startedAt     DateTime
  finishedAt    DateTime?
  durationMs    Int?
  scannedCount  Int?
  affectedCount Int?
  message       String?
  errorStack    String?
  metaJson      Json?
  triggeredBy   String?
  retryOfRunId  String?

  createdAt DateTime @default(now())

  @@index([jobCode, createdAt])
  @@index([status, createdAt])
}

model Interview {
  id                 String          @id @default(cuid())
  caseId             String
  questionSetId      String?
  questionSetCode    String?
  questionSetVersion String?
  status             InterviewStatus @default(NOT_STARTED)
  startedAt          DateTime?
  completedAt        DateTime?
  answersJson        Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  voiceTranscripts VoiceTranscript[]

  @@index([caseId, status])
}

/// Phase 5-B — 음성 STT 결과 초안 저장. 인터뷰 답변(`Interview.answersJson`)에는 `CONFIRMED` 이후 API에서만 반영해야 한다.
model VoiceTranscript {
  id     String @id @default(cuid())
  caseId String
  /// `Interview.answersJson` 키 규약과 동일(예 공부호 `gongbuho.*` 포함).
  questionKey     String
  createdByUserId String
  interviewId     String?

  status VoiceTranscriptStatus @default(CAPTURED)

  draftText String? @db.Text

  /// 원본 오디오 옵션 — 기본 false (`docs/voice/VOICE_PRIVACY_AND_RETENTION_POLICY.md`).
  storeOriginalAudio      Boolean @default(false)
  originalAudioStorageKey String?

  /// Draft 상태 TTL 만료 목표 시각 앱 레이어가 설정한다(`VOICE_TRANSCRIPT_DRAFT_TTL_HOURS_DEFAULT`).
  expiresAt DateTime?

  confirmedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case        Case                       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy   User                       @relation("VoiceTranscriptCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  interview   Interview?                 @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  traces      VoiceInteractionTrace[]

  @@index([caseId, questionKey, status])
  @@index([caseId, status, expiresAt])
}

/// Phase 5-B Voice 사건 타임라인 append-only 이벤트(`docs/voice/VOICE_INTERVIEW_FLOW.md` §5).
model VoiceInteractionTrace {
  id                String                       @id @default(cuid())
  caseId            String
  voiceTranscriptId String
  event             VoiceInteractionTraceEvent
  payloadJson       Json?
  actorUserId       String?

  createdAt DateTime @default(now())

  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  voiceTranscript VoiceTranscript @relation(fields: [voiceTranscriptId], references: [id], onDelete: Cascade)
  actor           User?           @relation("VoiceInteractionTraceActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([voiceTranscriptId, createdAt])
}

/// 공부호 패킷 정의 — 본문은 `packetJson` 단일 블록(SSOT 동일 키). 인덱싱용 중복 필드만 컬럼으로 둠.
model GongbuhoPacket {
  id       String               @id @default(cuid())
  code     String
  version  String
  name     String
  domain   String
  caseType String?
  status   GongbuhoPacketStatus @default(DRAFT)

  packetJson Json

  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  traces         GongbuhoTrace[]
  createdByUser  User?           @relation("GongbuhoPacketCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser User?           @relation("GongbuhoPacketApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([code, version])
  @@index([code])
  @@index([caseType])
  @@index([status])
  @@index([createdByUserId])
  @@index([approvedByUserId])
}

/// 사건별 공부호 적용 스냅샷/감사 흔적 — `version`은 적용 시점 패킷 버전(필드 매핑의 `appliedVersion`과 동일 의미)
model GongbuhoTrace {
  id String @id @default(cuid())

  caseId           String
  gongbuhoPacketId String

  code    String
  version String

  inputSnapshot       Json?
  outputSnapshot      Json?
  validationResult    Json?
  riskFlags           Json?
  expertReviewPoints  Json?
  humanApprovalStatus String?

  createdAt DateTime @default(now())

  case           Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  gongbuhoPacket GongbuhoPacket @relation(fields: [gongbuhoPacketId], references: [id], onDelete: Restrict)

  @@index([caseId])
  @@index([code, version])
  @@index([gongbuhoPacketId])
}

