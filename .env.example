# App
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_VERSION=2026.04.18-ops-final
# 실제 서비스 오리진과 반드시 일치 (OAuth 리디렉트·링크·sitemap/OG metadataBase)
APP_BASE_URL=https://your-domain.com
# 클라이언트 절대 URL이 필요한 기능·sitemap 보조(미설정 시 APP_BASE_URL·Vercel 호스트 사용)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# 검색 색인: 프리뷰(Vercel preview/development)·staging(NEXT_PUBLIC_APP_ENV=staging)은 기본 전면 차단
# 운영에서 긴급 차단 시: ROBOTS_DISALLOW_ALL=true
# ROBOTS_DISALLOW_ALL=false

# sitemap lastmod 고정(ISO 8601). 비우면 배포 시점에 가깝게 갱신
# SITEMAP_LASTMOD_ISO=2026-05-07T00:00:00.000Z

# Auth
JWT_SECRET=replace_me_with_long_random_secret
BCRYPT_SALT_ROUNDS=12
# 운영 배포 시 아래 정합성 권장:
# - HTTPS 서비스: APP_BASE_URL=https://실제도메인 , AUTH_COOKIE_SECURE=true(또는 미설정+https URL이면 자동 true)
# - 로컬/HTTP 테스트: APP_BASE_URL=http://localhost:3000 , AUTH_COOKIE_SECURE=false
# - JWT_SECRET: 충분히 긴 랜덤 문자열
# - DATABASE_URL: 운영 DB 연결 문자열
#
# 세션/OAuth 쿠키 Secure 플래그(선택). 비우면 APP_BASE_URL 이 https:// 이면 true, http:// 이면 false.
# HTTP로 서비스하는 production 에서 로그인 쿠키가 안 잡히면 false 로 두거나 APP_BASE_URL 을 http:// 로 맞춤.
# AUTH_COOKIE_SECURE=false

# 변호사 가입 IP 지문 HMAC salt(16자 이상 권장). 미설정 시 JWT_SECRET 기반 파생값 사용.
# LAWYER_SIGNUP_RISK_IP_SALT=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
# 배포 시 APP_BASE_URL / AUTH_COOKIE_SECURE / JWT_SECRET / DATABASE_URL 은 서로 맞는지 검증할 것.

# Cron / internal protection
CRON_SECRET=replace_me_with_long_random_secret

# Feature flags
NEXT_PUBLIC_FF_OPS_QUEUE_BULK_EDIT=true
NEXT_PUBLIC_FF_OPS_QUEUE_REBALANCE_APPLY=true
NEXT_PUBLIC_FF_OPS_QUEUE_WIP_SETTINGS_EDIT=true
NEXT_PUBLIC_FF_OPS_QUEUE_OPTIMISTIC_UI=true

# OpenAI (문서 초안 단락 generate·재생성 선택)
# OPENAI_API_KEY=
# OPENAI_DOCUMENT_GENERATE_MODEL=gpt-5.2
# OPENAI_PARAGRAPH_REWRITE_MODEL=gpt-5.2
# OPENAI_CASE_SUMMARY_MODEL=gpt-5.2
# CASE_SUMMARY_AI_MODE=RULE_BASED
# AI_GOVERNANCE_AI_ENABLED=true
# AI_GOVERNANCE_TENANT_ID=default
# AI_GOVERNANCE_MONTHLY_TOKEN_BUDGET=
# AI_GOVERNANCE_MAX_LLM_CALLS_PER_CASE=

# 공식 서식 원문(prompt) 길이 상한(LegalFormSource.parsedText 발췌)
# DOC_GEN_OFFICIAL_FORM_TEXT_MAX_CHARS=14000

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info

# Playwright (`npm run test:e2e` — 로컬 기본)
PLAYWRIGHT_BASE_URL=http://localhost:3000
# 변호사 자격검증 승인 전후 E2E (선택): 로컬 서버 + DB에 계정 준비 후
# E2E_LAWYER_VERIFICATION_SMOKE=1
# E2E_LAWYER_PENDING_EMAIL=
# E2E_LAWYER_PENDING_PASSWORD=
# E2E_LAWYER_APPROVED_EMAIL=
# E2E_LAWYER_APPROVED_PASSWORD=
# 스테이징 E2E: 오리진만 바꾼 뒤 `npm run test:e2e:staging` (localhost 기본값은 스크립트에서 거부)
# PLAYWRIGHT_BASE_URL=https://your-staging-host.example.com

# Illegal Lending Storage
ILLEGAL_LENDING_STORAGE_DRIVER=local
# local | s3 | r2 | supabase

ILLEGAL_LENDING_UPLOAD_ROOT=.private-uploads/illegal-lending

# S3 / R2 compatible
ILLEGAL_LENDING_S3_BUCKET=
ILLEGAL_LENDING_S3_REGION=auto
ILLEGAL_LENDING_S3_ENDPOINT=
ILLEGAL_LENDING_S3_ACCESS_KEY_ID=
ILLEGAL_LENDING_S3_SECRET_ACCESS_KEY=
ILLEGAL_LENDING_S3_FORCE_PATH_STYLE=true

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ILLEGAL_LENDING_SUPABASE_BUCKET=illegal-lending-private

# 변호사 자격증빙 업로드(P2) — `ILLEGAL_LENDING_STORAGE_DRIVER`·local 경로·S3 설정을 그대로 사용합니다.
# 전용 버킷 이름만 다른 경우에만 설정(미설정 시 `ILLEGAL_LENDING_S3_BUCKET` 등 사용).
# LAWYER_VERIFICATION_S3_BUCKET=

# 변호사 증빙 관리자 열람(P3) — presigned / 내부 content-token URL 만료(초). 미설정 시 기본 120, 60~300 클램프.
# LAWYER_VERIFICATION_SIGNED_URL_TTL_SEC=120
# 로컬 드라이버 content-token HMAC(미설정 시 JWT_SECRET 사용)
# LAWYER_VERIFICATION_DOWNLOAD_TOKEN_SECRET=

# P4 legacy fileUrl → private storage 이관 스크립트(기본 dry-run, 적용 시 --apply):
# npm run migrate:lawyer-verification-docs
# npm run migrate:lawyer-verification-docs -- --apply --failures-out=./p4-failures.json --summary-out=./p4-summary.json

# PDF Korean Font
PDF_KOREAN_FONT_PATH=
# 예: /app/private/fonts/NotoSansKR-Regular.ttf

# Lawyer Auto Assignment
ILLEGAL_LENDING_AUTO_ASSIGN_ENABLED=true

# AI법친 홍보/분석 설정
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

NEXT_PUBLIC_AIBEOPCHIN_PROMO_ANALYTICS_ENABLED=false
NEXT_PUBLIC_AIBEOPCHIN_PROMO_POPUP_ENABLED=true
NEXT_PUBLIC_AIBEOPCHIN_PROMO_POPUP_COOLDOWN_HOURS=24

# A/B 테스트: A | B | auto
NEXT_PUBLIC_ILLEGAL_LENDING_PROMO_VARIANT=auto

# Jeonse Damage Promo
NEXT_PUBLIC_JEONSE_DAMAGE_PROMO_POPUP_ENABLED=true
NEXT_PUBLIC_JEONSE_DAMAGE_PROMO_POPUP_COOLDOWN_HOURS=24
NEXT_PUBLIC_JEONSE_DAMAGE_PROMO_VARIANT=auto

# Free Service Promo Popup Exposure Policy
# rotation | illegal_only | jeonse_only | disabled
NEXT_PUBLIC_AIBEOPCHIN_FREE_SERVICE_PROMO_MODE=rotation

# 팝업 순환 기준
# session | daily
NEXT_PUBLIC_AIBEOPCHIN_FREE_SERVICE_PROMO_ROTATION_SCOPE=daily
